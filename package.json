{
  "name": "@guardian-protocol/skill",
  "version": "0.2.1",
  "description": "Security and risk-management middleware skill for autonomous agents on X Layer — OKX BuildX Hackathon",
  "author": "GuardianTeam",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "guardian": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "guardian": "tsx src/cli.ts",
    "start:web": "tsx src/server.ts",
    "live-fire": "tsx scripts/live-fire.ts",
    "proof:deploy": "tsx scripts/deploy-proof-contract.ts",
    "proof:log": "tsx scripts/log-proof.ts"
  },
  "keywords": [
    "okx",
    "onchainos",
    "xlayer",
    "security",
    "agent-skill",
    "web3",
    "hackathon"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "lru-cache": "^11.3.3",
    "uuid": "^10.0.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
