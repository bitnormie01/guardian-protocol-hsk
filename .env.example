# GoPlus Security API (optional — free tier available)
GOPLUS_API_KEY=

# HashKey Chain RPC — Round-Robin Redundancy (Phase 2)
# Guardian rotates through all endpoints with 1500ms per-endpoint timeout.
# At minimum, provide HASHKEY_RPC_URL. Additional endpoints improve availability.
HASHKEY_RPC_URL=https://mainnet.hsk.xyz
HASHKEY_RPC_URL_2=https://hashkey.drpc.org
HASHKEY_RPC_URL_3=https://rpc.hashkeychain.com

# Guardian Protocol Configuration
GUARDIAN_SAFETY_THRESHOLD=70
GUARDIAN_MAX_SLIPPAGE_BPS=500
GUARDIAN_TX_SIMULATION_TIMEOUT_MS=10000
GUARDIAN_RPC_ENDPOINT_TIMEOUT_MS=1500
GUARDIAN_LOG_LEVEL=info
