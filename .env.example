# OKX OnchainOS API Credentials
OKX_API_KEY=your_api_key
OKX_SECRET_KEY=your_secret_key
OKX_PASSPHRASE=your_passphrase
OKX_PROJECT_ID=your_project_id

# X Layer RPC — Round-Robin Redundancy (Phase 2)
# Guardian rotates through all endpoints with 1500ms per-endpoint timeout.
# X Layer RPC latency can exceed 500ms under load — 1500ms gives 4.5s worst-case
# budget across 3 endpoints while staying within the 10s simulation timeout.
# At minimum, provide XLAYER_RPC_URL. Additional endpoints improve availability.
XLAYER_RPC_URL=https://rpc.xlayer.tech
XLAYER_RPC_URL_2=https://xlayerrpc.okx.com
XLAYER_RPC_URL_3=https://xlayer-rpc.publicnode.com

# Guardian Protocol Configuration
GUARDIAN_SAFETY_THRESHOLD=70
GUARDIAN_MAX_SLIPPAGE_BPS=500
GUARDIAN_TX_SIMULATION_TIMEOUT_MS=10000
GUARDIAN_RPC_ENDPOINT_TIMEOUT_MS=1500
GUARDIAN_LOG_LEVEL=info
